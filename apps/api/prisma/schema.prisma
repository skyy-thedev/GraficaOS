// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(EMPLOYEE)
  loja        Loja     @default(PAPER_OFFICE_I)
  jornadaEntrada String @default("10:00")
  jornadaSaida   String @default("18:30")
  avatarColor String   @default("#6c63ff")
  initials    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pontos Ponto[]
  folgas FolgaConfig[]
  artes  Arte[]  @relation("ArteResponsavel")
  vendas Venda[] @relation("VendaResponsavel")
  checklistRegistros ChecklistRegistro[]
}

model Ponto {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  date      DateTime    @default(now()) @db.Date
  entrada   DateTime?
  almoco    DateTime?
  retorno   DateTime?
  saida     DateTime?
  status    PontoStatus @default(NORMAL)
  encerramentoAutomatico Boolean @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, date])
}

model FolgaConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  diaSemana Int      // 0=DOM, 1=SEG, 2=TER, 3=QUA, 4=QUI, 5=SEX, 6=SAB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, diaSemana])
}

enum PontoStatus {
  NORMAL
  FOLGA
  FALTA
}

model Arte {
  id            String      @id @default(cuid())
  codigo        String      @unique // ex: ART-001
  clienteNome   String
  clienteNumero String
  orcamentoNum  String
  produto       ProdutoTipo
  quantidade    Int         @default(1)
  larguraCm     Int
  alturaCm      Int
  responsavelId String
  responsavel   User        @relation("ArteResponsavel", fields: [responsavelId], references: [id])
  status        ArteStatus  @default(TODO)
  urgencia      Urgencia    @default(NORMAL)
  prazo         DateTime?
  observacoes   String?
  arquivos      Arquivo[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Arquivo {
  id           String   @id @default(cuid())
  arteId       String
  arte         Arte     @relation(fields: [arteId], references: [id], onDelete: Cascade)
  nomeOriginal String
  nomeStorage  String
  tipo         String // "image/jpeg", "application/pdf"
  tamanho      Int
  url          String
  createdAt    DateTime @default(now())
}

model Venda {
  id              String          @id @default(cuid())
  codigo          String          @unique
  clienteNome     String?
  clienteDocumento String?
  clienteTelefone String?
  produto         ProdutoTipo?
  produtoNome     String
  pricingProductId String?
  quantidade      Int             @default(1)
  valorUnitario   Float
  valorTotal      Float
  valorOriginal   Float?
  descontoPercent Float           @default(0)
  subtotalBase    Float?
  acabamentosValor Float          @default(0)
  urgenciaValor   Float           @default(0)
  sizeVariationId String?
  sizeVariationNome String?
  acabamentos     Json?
  pricingSnapshot Json?
  urgenciaNivel   PricingUrgencyLevel @default(NONE)
  status          VendaStatus     @default(AGUARDANDO)
  formaPagamento  FormaPagamento?
  observacoes     String?
  responsavelId   String
  responsavel     User            @relation("VendaResponsavel", fields: [responsavelId], references: [id])
  pricingProduct  Product?        @relation(fields: [pricingProductId], references: [id], onDelete: SetNull)
  finalizadaEm    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([responsavelId, createdAt])
  @@index([pricingProductId])
}

model PricingSettings {
  id                   String   @id @default("default")
  outsourcedMultiplier Float    @default(2.5)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Product {
  id               String               @id @default(cuid())
  name             String               @unique
  description      String?
  category         String
  premiumCategory  String?
  legacyProdutoTipo ProdutoTipo?
  isOutsourced     Boolean              @default(false)
  supplierCost     Float?
  pricingMode      PricingMode          @default(PROGRESSIVE)
  fixedUnitPrice   Float?
  urgencyEnabled   Boolean              @default(true)
  active           Boolean              @default(true)
  sortOrder        Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  pricingTiers     PricingTier[]
  sizeVariations   ProductSizeVariation[]
  finishLinks      ProductFinishProduct[]
  vendas           Venda[]

  @@index([active, sortOrder])
  @@index([category, premiumCategory])
}

model PricingTier {
  id          String   @id @default(cuid())
  productId   String
  minQuantity Int
  maxQuantity Int?
  unitPrice   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, minQuantity])
}

model ProductFinish {
  id          String       @id @default(cuid())
  name        String       @unique
  type        String
  value       Float
  pricingType ModifierType
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  products    ProductFinishProduct[]

  @@index([active, name])
}

model ProductFinishProduct {
  productId String
  finishId  String

  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  finish    ProductFinish @relation(fields: [finishId], references: [id], onDelete: Cascade)

  @@id([productId, finishId])
}

model ProductSizeVariation {
  id          String       @id @default(cuid())
  productId   String
  name        String
  widthCm     Float?
  heightCm    Float?
  value       Float        @default(0)
  pricingType ModifierType @default(FIXED)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Loja {
  PAPER_OFFICE_I
  PAPER_OFFICE_II
}

enum ArteStatus {
  TODO
  DOING
  REVIEW
  DONE
}

enum Urgencia {
  LOW
  NORMAL
  HIGH
}

enum ProdutoTipo {
  AZULEJO
  BANNER
  ADESIVO
  ADESIVO_RECORTE
  LONA
  PLACA
  FAIXA
  CARTAO_VISITA
  PANFLETO
  FOLDER
  PERFURADO
  ENVELOPAMENTO
  BACKLIGHT
  OUTRO
}

enum VendaStatus {
  AGUARDANDO
  CONCLUIDA
}

enum FormaPagamento {
  PIX
  DINHEIRO
  DEBITO
  CREDITO
  BOLETO
  TRANSFERENCIA
  OUTRO
}

enum PricingMode {
  PROGRESSIVE
  FIXED
  OUTSOURCED
}

enum ModifierType {
  FIXED
  PERCENTAGE
}

enum PricingUrgencyLevel {
  NONE
  PRIORITARIO
  EXPRESS
}

model ChecklistItem {
  id            String   @id @default(cuid())
  titulo        String
  descricao     String?
  horarioLimite String?  // formato "HH:MM"
  ordem         Int      @default(0)
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registros ChecklistRegistro[]
}

model ChecklistRegistro {
  id        String        @id @default(cuid())
  itemId    String
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  data      DateTime      @db.Date
  feito     Boolean       @default(false)
  feitoEm   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([itemId, data])
}
