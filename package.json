{
  "name": "graficaos",
  "version": "1.0.0",
  "private": true,
  "description": "GráficaOS — Sistema de gestão para gráficas",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build": "npm run build:api && npm run build:web",
    "start:api": "npm run start -w apps/api",
    "render:build": "npm run db:generate && npm run build:api",
    "render:start": "npm run db:migrate:deploy && npm run start:api",
    "db:generate": "npm run db:generate -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:migrate:deploy": "npm run db:migrate:deploy -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:studio": "npm run db:studio -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "date-fns-tz": "^3.2.0"
  }
}
