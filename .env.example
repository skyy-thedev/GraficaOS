# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/graficaos"

# JWT
JWT_SECRET="seu-secret-aqui"
JWT_REFRESH_SECRET="seu-refresh-secret-aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=25

# Servidor
PORT=3333
NODE_ENV="development"

# Frontend canônico para links públicos (ex.: QR code)
FRONTEND_URL="http://localhost:5173"

# Origens adicionais liberadas no CORS, separadas por vírgula
# Exemplo de produção:
# FRONTEND_URLS="https://graficaos.vercel.app,https://www.graficaos.com.br"
FRONTEND_URLS=""

# Email / Resend
RESEND_API_KEY=""
EMAIL_FROM="GráficaOS <onboarding@resend.dev>"

# SMTP fallback
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="GráficaOS <noreply@graficaos.com>"

# Regras de ponto
HORARIO_ENTRADA_PONTUAL="10:15"
